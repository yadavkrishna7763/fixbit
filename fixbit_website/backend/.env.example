PORT=5050
NODE_ENV=development

# Use either DB_URL/DATABASE_URL or the individual MySQL fields below.
DB_URL=
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=fixbit
DB_CONNECTION_LIMIT=10

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Primary frontend origin for deployment.
FRONTEND_URL=https://your-frontend-url.netlify.app

# Comma-separated frontend origins for CORS.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:3000

# Comma-separated admin account emails.
ADMIN_EMAILS=admin@fixbit.com

RATE_LIMIT_MAX=300

